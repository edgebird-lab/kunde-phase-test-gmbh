---
import { cssUrlValue } from '../../../thunder/builder/src/tokens.ts';

export interface Props {
  padding?: 'none'|'sm'|'md'|'lg';
  fullWidth?: boolean;
  background?: { color?: string|null; image?: string|null; overlay?: number|null } | null;
  label?: string;
  /** True für die erste Section mit Hintergrundbild: rendert <img> statt CSS background-image für besseres LCP. */
  isLcp?: boolean;
  [key: string]: unknown;
}
const { padding = 'lg', fullWidth = true, background = null, label = '', isLcp = false, ...rest } = Astro.props;
const padMap: Record<string, string> = { none: '0', sm: '20px 5vw', md: '36px 5vw', lg: '56px 5vw' };

function dxBgUrl(rawSrc: string, width: number): string {
  try {
    if (!/https?:\/\/.+\/assets\//.test(rawSrc)) return rawSrc;
    const u = new URL(rawSrc);
    u.searchParams.set('width', String(width));
    u.searchParams.set('format', 'webp');
    u.searchParams.set('quality', '70');
    return u.toString();
  } catch {
    return rawSrc;
  }
}

const bgStyle: string[] = [];
if (background?.color) bgStyle.push(`background-color: ${background.color}`);
if (background?.image && !isLcp) {
  bgStyle.push(`background-image: ${cssUrlValue(dxBgUrl(background.image, 1920))}`);
  bgStyle.push(`background-size: cover`);
  bgStyle.push(`background-position: center`);
}
const overlayPct = background?.overlay ?? 0;
const showOverlay = !!(background?.image && overlayPct > 0);

const lcpSrc = (isLcp && background?.image) ? dxBgUrl(background.image, 1920) : null;
const lcpSrcset = (isLcp && background?.image)
  ? [800, 1200, 1920].map((w) => `${dxBgUrl(background!.image!, w)} ${w}w`).join(', ')
  : null;
---
<section
  class={`thunder-section ${fullWidth ? 'sec-full' : 'sec-narrow'}`}
  data-label={label}
  style={`padding:${padMap[padding] || padMap.md}; ${bgStyle.join(';')}`}
  {...rest}
>
  {lcpSrc && (
    <img
      class="thunder-section-bg-img"
      src={lcpSrc}
      srcset={lcpSrcset || undefined}
      sizes="100vw"
      alt=""
      aria-hidden="true"
      fetchpriority="high"
      loading="eager"
      decoding="sync"
    />
  )}
  {showOverlay && <div class="thunder-section-overlay" style={`background: rgba(0,0,0, ${overlayPct/100})`}></div>}
  <div class="thunder-section-inner">
    <slot />
  </div>
</section>
<style>
  .thunder-section { position: relative; color: var(--text); }
  .thunder-section-overlay { position: absolute; inset: 0; pointer-events: none; }
  .thunder-section-inner { position: relative; z-index: 1; }
  .sec-narrow .thunder-section-inner { max-width: var(--container-max); margin-inline: auto; }
  .thunder-section-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
</style>
