---
export interface Props { src?: string; provider?: 'embed'|'upload'; }
const { src = '', provider = 'embed' } = Astro.props;
---
{src ? (
  provider === 'upload' ? (
    <video class="blk-video" controls preload="metadata" src={src}></video>
  ) : (
    <div class="blk-video-frame">
      <iframe src={src} title="Video" loading="lazy" allow="encrypted-media; fullscreen" allowfullscreen></iframe>
    </div>
  )
) : (
  <div class="blk-video-placeholder">▶ VIDEO</div>
)}
<style>
  .blk-video, .blk-video-frame, .blk-video-placeholder {
    width: 100%; aspect-ratio: 16 / 9; border-radius: var(--radius); overflow: hidden; background: var(--bg2);
  }
  .blk-video-frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  .blk-video-placeholder {
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); font-weight: 700; letter-spacing: .15em;
    border: 2px dashed color-mix(in srgb, var(--accent) 50%, transparent);
  }
</style>
